{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentalVsRuntimeJudgeResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "passed",
    "summary",
    "inconclusive",
    "violations",
    "verdict",
    "confidence",
    "evidence",
    "required_fix"
  ],
  "properties": {
    "passed": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "inconclusive": {
      "type": "boolean"
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "location",
          "reason"
        ],
        "properties": {
          "location": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "clear",
        "confused",
        "needs_human_review"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "location",
          "reason"
        ],
        "properties": {
          "location": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "required_fix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "summary"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "wording",
            "scope_boundary",
            "remove_runtime_promise",
            "sanitize_example",
            "stop_resolved_memory_as_next_step"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
