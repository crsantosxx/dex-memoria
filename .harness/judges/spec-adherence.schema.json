{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harness://judges/spec-adherence.schema.json",
  "title": "SpecAdherenceJudgeOutput",
  "description": "Normalized judge output for the spec-adherence rubric. Conforms to the shared SensorOutput schema (SPEC §9).",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool", "regulation", "passed", "summary", "violations"],
  "properties": {
    "tool": {
      "type": "string",
      "const": "spec-adherence"
    },
    "regulation": {
      "type": "string",
      "const": "behaviour"
    },
    "passed": {
      "type": "boolean",
      "description": "True iff the artifact satisfies the spec without add/subtract scope. Must be false when inconclusive is true."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "One- to three-sentence factual summary of the verdict."
    },
    "inconclusive": {
      "type": "boolean",
      "default": false,
      "description": "True when the judge cannot decide with high confidence (e.g. artifact too large, ambiguous spec)."
    },
    "inconclusiveReason": {
      "type": "string",
      "description": "Required when inconclusive is true. Short machine-friendly token, e.g. 'target_too_large', 'ambiguous_spec'."
    },
    "violations": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/definitions/Violation" }
    }
  },
  "definitions": {
    "Violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "what", "why", "remediation"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        },
        "what": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 },
        "remediation": { "type": "string", "minLength": 1 },
        "filesAffected": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        },
        "linesAffected": {
          "type": "array",
          "default": [],
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer", "minimum": 0 }
          }
        },
        "guideUri": {
          "type": "string",
          "pattern": "^harness://"
        }
      }
    }
  }
}
