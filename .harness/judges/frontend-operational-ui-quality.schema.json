{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harness://judges/frontend-operational-ui-quality.schema.json",
  "title": "FrontendOperationalUiQualityJudgeOutput",
  "description": "Normalized judge output for frontend operational UI quality review.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool", "regulation", "passed", "summary", "violations"],
  "properties": {
    "tool": {
      "type": "string",
      "const": "frontend-operational-ui-quality"
    },
    "regulation": {
      "type": "string",
      "const": "fitness"
    },
    "passed": {
      "type": "boolean",
      "description": "True only when the visual evidence supports the operational UI quality criteria."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "One- to three-sentence factual summary of the verdict."
    },
    "inconclusive": {
      "type": "boolean",
      "default": false,
      "description": "True when screenshots, viewport, finalUrl, diff, or target context are insufficient."
    },
    "inconclusiveReason": {
      "type": "string",
      "description": "Required when inconclusive is true. Short machine-friendly token."
    },
    "violations": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/definitions/Violation" }
    }
  },
  "definitions": {
    "Violation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "what", "why", "remediation"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "info"]
        },
        "what": {
          "type": "string",
          "minLength": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "remediation": {
          "type": "string",
          "minLength": 1
        },
        "filesAffected": {
          "type": "array",
          "default": [],
          "items": { "type": "string" }
        },
        "linesAffected": {
          "type": "array",
          "default": [],
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer", "minimum": 0 }
          }
        },
        "guideUri": {
          "type": "string",
          "pattern": "^harness://"
        }
      }
    }
  }
}
